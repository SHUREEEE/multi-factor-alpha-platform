# Python bytecode and test caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Local editor and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
~$*

# Binary office exports; keep Markdown/text interview notes in Git instead.
*.docx
*.pptx
*.xlsx

# Local logs and temporary outputs
*.log
tmp/
temp/
test_acceptance_gate*/
test_acceptance_gates*/

# Generated research artifacts.
# Keep curated reports and small headline artifacts only when intentionally
# committed. Large panels should use the data policy instead of normal Git.
*.parquet
*.pkl
*.pickle
*.feather
*.h5
*.hdf5
!data/
!data/README.md

# Generated image outputs
results/**/*.png

# Generated v2 institutional validation and attribution bundles.
# Commit Markdown reports and small JSON/CSV evidence intentionally; keep
# reproducible large panels out of normal Git history.
data/raw/sec_shares_outstanding.parquet
data/processed/daily_fundamentals.parquet
results/institutional_validation/*.parquet
results/market_cap_ready_attribution/**/*.parquet
results/market_cap_ready_attribution/**/*.png

# V4 walk-forward selection keeps top-level review artifacts in Git, while
# nested per-window replay directories are reproducible intermediate outputs.
results/v4_walk_forward_selection_full/*/
